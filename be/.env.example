# Application
APP_NAME=BotBot
DEBUG=True
SECRET_KEY=your-secret-key-change-this-in-production
API_PREFIX=/api

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=botbot

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
REFRESH_TOKEN_EXPIRE_MINUTES=43200

# SMS Service (Aliyun)
ALIYUN_ACCESS_KEY_ID=your-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-access-key-secret
ALIYUN_SMS_SIGN_NAME=your-sms-sign
ALIYUN_SMS_TEMPLATE_CODE=your-template-code

# Claude API
ANTHROPIC_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# CORS - 允许访问的前端地址
# 支持三种格式:
# 1. 所有来源（通配符）: CORS_ORIGINS=*
# 2. JSON 数组: CORS_ORIGINS=["http://localhost:3000","http://example.com:3000"]
# 3. 逗号分隔: CORS_ORIGINS=http://localhost:3000,http://example.com:3000
# 4. 单个地址: CORS_ORIGINS=http://localhost:3000

# 开发和生产环境 - 允许所有来源访问
CORS_ORIGINS=*

# 如果需要限制特定域名，使用以下格式：
# CORS_ORIGINS=["http://botbot.biz:3000","http://47.83.230.114:3000","http://localhost:3000"]

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# Payment Configuration
RECHARGE_EXCHANGE_RATE=10.0
WITHDRAWAL_EXCHANGE_RATE=10.0
PLATFORM_FEE_RATE=0.10
MIN_RECHARGE_AMOUNT=1.0
MIN_WITHDRAWAL_AMOUNT=100.0

# Admin Configuration
# Super admin phone number (will be automatically granted admin role on startup)
SUPER_ADMIN_PHONE=13800138000
# Minimum platform withdrawal amount (in shrimp food, 1000kg = 100 RMB)
MIN_PLATFORM_WITHDRAWAL_AMOUNT=1000.0

# Alipay Configuration
ALIPAY_APP_ID=your-alipay-app-id
ALIPAY_PRIVATE_KEY_PATH=/path/to/alipay_private_key.pem
ALIPAY_PUBLIC_KEY_PATH=/path/to/alipay_public_key.pem
ALIPAY_NOTIFY_URL=https://your-domain.com/api/payment/alipay/notify
ALIPAY_RETURN_URL=https://your-domain.com/recharge/success
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# WeChat Pay Configuration
WECHAT_APP_ID=your-wechat-app-id
WECHAT_MCH_ID=your-merchant-id
WECHAT_API_KEY=your-api-key
WECHAT_APICLIENT_CERT_PATH=/path/to/apiclient_cert.pem
WECHAT_APICLIENT_KEY_PATH=/path/to/apiclient_key.pem
WECHAT_NOTIFY_URL=https://your-domain.com/api/payment/wechat/notify
