# ================================
# 生产环境配置模板
# ================================
# 使用说明：
# 1. 复制此文件为 .env.production
# 2. 运行 ../generate_secrets.sh 生成密钥
# 3. 填入真实的配置信息
# 4. 不要将 .env.production 提交到 Git
# ================================

# 应用设置
APP_NAME=BotBot
DEBUG=False
API_PREFIX=/api

# 安全密钥（必须修改！）
# 运行 openssl rand -hex 32 生成
SECRET_KEY=<运行: openssl rand -hex 32>
JWT_SECRET_KEY=<运行: openssl rand -hex 32>

# CORS配置（改为你的域名）
CORS_ORIGINS=["https://yourdomain.com","https://www.yourdomain.com"]

# MongoDB配置
MONGODB_URL=mongodb://username:password@your-mongodb-host:27017/botbot
MONGODB_DB_NAME=botbot

# JWT配置
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# 短信服务（阿里云）
ALIYUN_ACCESS_KEY_ID=<your-aliyun-access-key>
ALIYUN_ACCESS_KEY_SECRET=<your-aliyun-secret>
ALIYUN_SMS_SIGN_NAME=<your-sms-sign>
ALIYUN_SMS_TEMPLATE_CODE=<your-template-code>

# Claude AI
ANTHROPIC_API_KEY=<your-anthropic-api-key>
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# 频率限制
RATE_LIMIT_PER_MINUTE=100

# 支付配置
RECHARGE_EXCHANGE_RATE=10.0
WITHDRAWAL_EXCHANGE_RATE=10.0
PLATFORM_FEE_RATE=0.10
MIN_RECHARGE_AMOUNT=1.0
MIN_WITHDRAWAL_AMOUNT=100.0

# 管理员配置
SUPER_ADMIN_PHONE=<your-admin-phone>
MIN_PLATFORM_WITHDRAWAL_AMOUNT=1000.0

# 支付宝配置
ALIPAY_APP_ID=<your-alipay-app-id>
ALIPAY_PRIVATE_KEY_PATH=/app/certs/alipay_private_key.pem
ALIPAY_PUBLIC_KEY_PATH=/app/certs/alipay_public_key.pem
ALIPAY_NOTIFY_URL=https://api.yourdomain.com/api/payment/alipay/notify
ALIPAY_RETURN_URL=https://yourdomain.com/recharge/success
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# 微信支付配置
WECHAT_APP_ID=<your-wechat-app-id>
WECHAT_MCH_ID=<your-merchant-id>
WECHAT_API_KEY=<your-wechat-api-key>
WECHAT_APICLIENT_CERT_PATH=/app/certs/apiclient_cert.pem
WECHAT_APICLIENT_KEY_PATH=/app/certs/apiclient_key.pem
WECHAT_NOTIFY_URL=https://api.yourdomain.com/api/payment/wechat/notify
