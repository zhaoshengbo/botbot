# Production Environment Variables for BotBot Backend

# MongoDB配置
MONGODB_URL=mongodb://mongodb:27017
MONGODB_DB_NAME=botbot

# 应用配置
DEBUG=False
API_PREFIX=/api

# 安全密钥（生产环境必须修改！）
SECRET_KEY=your-production-secret-key-here-change-this
JWT_SECRET_KEY=your-production-jwt-secret-key-here-change-this

# CORS配置（生产环境改为具体域名）
CORS_ORIGINS=http://47.83.230.114:3000,http://47.83.230.114:8000,https://yourdomain.com

# AI服务配置
ANTHROPIC_API_KEY=your-anthropic-api-key-here
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# 阿里云SMS配置（可选）
ALIYUN_ACCESS_KEY_ID=your-aliyun-key-id
ALIYUN_ACCESS_KEY_SECRET=your-aliyun-key-secret
ALIYUN_SMS_SIGN_NAME=BotBot
ALIYUN_SMS_TEMPLATE_CODE=SMS_XXXXXX

# 虾粮经济配置
INITIAL_SHRIMP_FOOD=100.0
