version: '3.8'

# Production Docker Compose Configuration
# Usage: docker-compose -f docker-compose.prod.yml up -d
# Make sure to create .env.prod file with all required environment variables

services:
  mongodb:
    image: mongo:6.0
    container_name: botbot-mongodb
    restart: always
    ports:
      - "27017:27017"
    environment:
      MONGO_INITDB_DATABASE: botbot
      MONGO_INITDB_ROOT_USERNAME: ${MONGO_USERNAME:-admin}
      MONGO_INITDB_ROOT_PASSWORD: ${MONGO_PASSWORD}
    volumes:
      - mongodb_data:/data/db
    networks:
      - botbot-network
    healthcheck:
      test: echo 'db.runCommand("ping").ok' | mongosh localhost:27017/test --quiet
      interval: 10s
      timeout: 5s
      retries: 5

  backend:
    build:
      context: ./be
      dockerfile: Dockerfile
    container_name: botbot-backend
    restart: always
    ports:
      - "8000:8000"
    environment:
      # MongoDB Configuration
      - MONGODB_URL=mongodb://${MONGO_USERNAME:-admin}:${MONGO_PASSWORD}@mongodb:27017/botbot?authSource=admin
      - MONGODB_DB_NAME=botbot

      # Application Configuration
      - DEBUG=False
      - SECRET_KEY=${SECRET_KEY}
      - JWT_SECRET_KEY=${JWT_SECRET_KEY}
      - API_PREFIX=/api
      - CORS_ORIGINS=${FRONTEND_URL}

      # AI Service
      - ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY:-}
      - CLAUDE_MODEL=claude-3-5-sonnet-20241022

      # SMS Service (Aliyun)
      - ALIYUN_ACCESS_KEY_ID=${ALIYUN_ACCESS_KEY_ID:-}
      - ALIYUN_ACCESS_KEY_SECRET=${ALIYUN_ACCESS_KEY_SECRET:-}
      - ALIYUN_SMS_SIGN_NAME=${ALIYUN_SMS_SIGN_NAME:-}
      - ALIYUN_SMS_TEMPLATE_CODE=${ALIYUN_SMS_TEMPLATE_CODE:-}

      # Payment Configuration - WeChat Pay
      - WECHAT_PAY_MCHID=${WECHAT_PAY_MCHID:-}
      - WECHAT_PAY_KEY=${WECHAT_PAY_KEY:-}
      - WECHAT_PAY_APIV3_KEY=${WECHAT_PAY_APIV3_KEY:-}
      - WECHAT_PAY_SERIAL_NO=${WECHAT_PAY_SERIAL_NO:-}
      - WECHAT_PAY_PRIVATE_KEY=${WECHAT_PAY_PRIVATE_KEY:-}
      - WECHAT_PAY_NOTIFY_URL=${BACKEND_URL}/api/payment/callback/wechat

      # Payment Configuration - Alipay
      - ALIPAY_APP_ID=${ALIPAY_APP_ID:-}
      - ALIPAY_PRIVATE_KEY=${ALIPAY_PRIVATE_KEY:-}
      - ALIPAY_PUBLIC_KEY=${ALIPAY_PUBLIC_KEY:-}
      - ALIPAY_NOTIFY_URL=${BACKEND_URL}/api/payment/callback/alipay
      - ALIPAY_RETURN_URL=${FRONTEND_URL}/payment/result

      # Shrimp Food Economy
      - INITIAL_SHRIMP_FOOD=100.0
      - RECHARGE_EXCHANGE_RATE=10.0
    depends_on:
      mongodb:
        condition: service_healthy
    networks:
      - botbot-network
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/api/health"]
      interval: 30s
      timeout: 10s
      retries: 3
    # Production command with multiple workers (no --reload)
    command: uvicorn app.main:app --host 0.0.0.0 --port 8000 --workers 4

  frontend:
    build:
      context: ./fe
      dockerfile: Dockerfile
      args:
        - NODE_ENV=production
        - NEXT_PUBLIC_API_URL=${BACKEND_URL}
    container_name: botbot-frontend
    restart: always
    ports:
      - "3000:3000"
    environment:
      - NEXT_PUBLIC_API_URL=${BACKEND_URL}
      - NODE_ENV=production
    depends_on:
      backend:
        condition: service_healthy
    networks:
      - botbot-network
    healthcheck:
      test: ["CMD", "wget", "--no-verbose", "--tries=1", "--spider", "http://localhost:3000"]
      interval: 30s
      timeout: 10s
      retries: 3

volumes:
  mongodb_data:
    driver: local

networks:
  botbot-network:
    driver: bridge
