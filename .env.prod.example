# Production Environment Variables for Docker Compose
# Copy this file to .env.prod and fill in your actual values
# Usage: docker-compose -f docker-compose.prod.yml --env-file .env.prod up -d

# ============================
# Server Configuration
# ============================
BACKEND_URL=http://47.83.230.114:8000
FRONTEND_URL=http://47.83.230.114:3000

# ============================
# MongoDB Configuration
# ============================
MONGO_USERNAME=admin
MONGO_PASSWORD=your-strong-mongodb-password-here

# ============================
# Application Security
# ============================
SECRET_KEY=your-production-secret-key-at-least-32-characters-long
JWT_SECRET_KEY=your-production-jwt-secret-key-at-least-32-characters-long

# ============================
# AI Service (Anthropic Claude)
# ============================
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================
# SMS Service (Aliyun) - Optional
# ============================
ALIYUN_ACCESS_KEY_ID=your-aliyun-access-key-id
ALIYUN_ACCESS_KEY_SECRET=your-aliyun-access-key-secret
ALIYUN_SMS_SIGN_NAME=BotBot
ALIYUN_SMS_TEMPLATE_CODE=SMS_XXXXXX

# ============================
# WeChat Pay Configuration
# ============================
WECHAT_PAY_MCHID=your-wechat-mchid
WECHAT_PAY_KEY=your-wechat-pay-key-32-characters
WECHAT_PAY_APIV3_KEY=your-wechat-apiv3-key
WECHAT_PAY_SERIAL_NO=your-certificate-serial-number
# Note: WECHAT_PAY_PRIVATE_KEY should be the full private key content
# You may need to use docker secrets or volume mount for this
WECHAT_PAY_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYourPrivateKeyContentHere\n-----END PRIVATE KEY-----

# ============================
# Alipay Configuration
# ============================
ALIPAY_APP_ID=your-alipay-app-id
# Note: ALIPAY_PRIVATE_KEY and ALIPAY_PUBLIC_KEY should be the full key content
# Multi-line keys need proper escaping or use docker secrets
ALIPAY_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nYourPrivateKeyContentHere\n-----END RSA PRIVATE KEY-----
ALIPAY_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nYourPublicKeyContentHere\n-----END PUBLIC KEY-----

# ============================
# Notes
# ============================
# 1. NEVER commit .env.prod to git
# 2. For multi-line keys (private keys), consider using Docker secrets or volume mounts
# 3. Generate strong random keys using: openssl rand -hex 32
# 4. Backup this file securely
# 5. Update BACKEND_URL and FRONTEND_URL with your actual domain/IP
