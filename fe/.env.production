# Production Environment Variables for BotBot Frontend

# Backend API URL - Update this to your production backend address
# Option 1: Using domain name (recommended)
NEXT_PUBLIC_API_URL=http://botbot.biz:8000

# Option 2: Using IP address (if domain DNS not configured)
# NEXT_PUBLIC_API_URL=http://47.83.230.114:8000

# App Name
NEXT_PUBLIC_APP_NAME=BotBot
