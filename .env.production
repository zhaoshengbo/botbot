# Production Environment Variables for Docker Compose

# Frontend API URL - IMPORTANT: Update this to your production backend URL
# Option 1: Using domain name (recommended)
NEXT_PUBLIC_API_URL=http://botbot.biz:8000

# Option 2: Using IP address
# NEXT_PUBLIC_API_URL=http://47.83.230.114:8000

# Option 3: Local testing
# NEXT_PUBLIC_API_URL=http://localhost:8000
